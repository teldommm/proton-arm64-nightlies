+
+void dinput_keyboard_android_compat_mirror_event( IDirectInputDevice8W *iface, DWORD vkey, DWORD scan_code, BOOL up )
+{
+#ifdef __ANDROID__
+    struct dinput_device *device, *targets[8];
+    UINT count = 0, i;
+
+    if (!getenv( "WINE_ANDROID_DINPUT_COMPAT" )) return;
+
+    EnterCriticalSection( &dinput_hook_crit );
+    LIST_FOR_EACH_ENTRY( device, &acquired_device_list, struct dinput_device, entry )
+    {
+        if (&device->IDirectInputDevice8W_iface == iface) continue;
+        if (!IsEqualGUID( &device->guid, &GUID_SysKeyboard )) continue;
+        if (device->status != STATUS_ACQUIRED) continue;
+        if (device->use_raw_input) continue;
+        if (device->user_format.dwDataSize != 272) continue;
+        dinput_device_internal_addref( device );
+        targets[count++] = device;
+        if (count >= ARRAY_SIZE( targets )) break;
+    }
+    LeaveCriticalSection( &dinput_hook_crit );
+
+    for (i = 0; i < count; ++i)
+    {
+        extern void dinput_keyboard_mirror_event( IDirectInputDevice8W *iface, DWORD vkey, DWORD scan_code, BOOL up );
+        dinput_keyboard_mirror_event( &targets[i]->IDirectInputDevice8W_iface, vkey, scan_code, up );
+        dinput_device_internal_release( targets[i] );
+    }
+#endif
+}
 
