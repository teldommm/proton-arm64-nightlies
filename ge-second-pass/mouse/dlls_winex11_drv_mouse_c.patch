         return FALSE;
     }
 
+#ifndef __ANDROID__
     pXFixesHideCursor( data->display, root_window );
+#endif
     XWarpPointer( data->display, root_window, root_window, 0, 0, 0, 0, pos.x, pos.y );
     data->warp_serial = NextRequest( data->display );
