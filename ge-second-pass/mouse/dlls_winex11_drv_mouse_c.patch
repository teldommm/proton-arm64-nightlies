     TRACE( "warped to %d,%d serial %lu\n", x, y, data->warp_serial );
     return TRUE;
@@ -1661,18 +1684,40 @@ BOOL X11DRV_MotionNotify( HWND hwnd, XEvent *xev )
     TRACE( "hwnd %p/%lx pos %d,%d is_hint %d serial %lu\n",
