+    {
+        TRACE( "pos %d,%d old serial %lu, ignoring\n", event->x, event->y, event->serial );
+        return FALSE;
+    }
+
     input.mi.mouseData   = 0;
-    input.mi.dwFlags     = MOUSEEVENTF_MOVE | MOUSEEVENTF_ABSOLUTE;
